# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cyberroulette

# WebSocket RPC endpoint for chain events (e.g. Alchemy, Infura wss://)
RPC_WSS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# CyberRoulette deployed contract address
CONTRACT_ADDRESS=0x...

# CyberRoulette factory contract address
FACTORY_ADDRESS=0x...

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Server port (default 3001)
PORT=3001
